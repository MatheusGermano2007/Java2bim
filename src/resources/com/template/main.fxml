<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane stylesheets="@style.css" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #1a1a1a;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.template.MainController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="70.0" prefWidth="900.0" spacing="20.0" style="-fx-background-color: #000000; -fx-border-color: #deff9a; -fx-border-width: 0 0 1 0;" BorderPane.alignment="CENTER">
            <children>
                <Label text="DevLang CRUD" textFill="#deff9a">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>
                </Label>
                <HBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                    <children>
                        <TextField fx:id="txtSearch" prefHeight="30.0" prefWidth="250.0" promptText="Pesquisar linguagem..." styleClass="text-field" />
                    </children>
                </HBox>
            </children>
            <padding>
                <Insets left="20.0" right="20.0" />
            </padding>
        </HBox>
    </top>

    <left>
        <VBox prefWidth="300.0" spacing="15.0" style="-fx-background-color: #1a1a1a; -fx-border-color: #333; -fx-border-width: 0 1 0 0;" BorderPane.alignment="CENTER">
            <children>
                <Label text="Dados da Linguagem" textFill="#deff9a">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>

                <VBox spacing="5.0">
                    <children>
                        <Label text="Nome *" textFill="#daffde" />
                        <TextField fx:id="txtNome" promptText="Ex: Java, Python..." styleClass="text-field" />
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label text="Criador *" textFill="#daffde" />
                        <TextField fx:id="txtCriador" promptText="Ex: James Gosling..." styleClass="text-field" />
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label text="Tipo" textFill="#daffde" />
                        <ComboBox fx:id="comboTipo" maxWidth="1.7976931348623157E308" promptText="Selecione o tipo..." styleClass="combo-box" />
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label text="Ano Criação" textFill="#daffde" />
                        <TextField fx:id="txtAno" promptText="Ex: 1995" styleClass="text-field" />
                    </children>
                </VBox>

                <VBox alignment="BOTTOM_CENTER" spacing="10.0" VBox.vgrow="ALWAYS">
                    <children>
                        <Button fx:id="btnSave" onAction="#acaoSalvar" maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="btn-salvar" text="SALVAR" />
                        <Button fx:id="btnClear" onAction="#limparCampos" maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="btn-limpar" text="LIMPAR" />
                    </children>
                </VBox>
            </children>
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
        </VBox>
    </left>

    <center>
        <VBox prefHeight="200.0" prefWidth="100.0" spacing="10.0" BorderPane.alignment="CENTER">
            <children>
                <TableView fx:id="tableView" prefHeight="450.0" prefWidth="560.0" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colNome" prefWidth="150.0" text="Nome" />
                        <TableColumn fx:id="colCriador" prefWidth="180.0" text="Criador" />
                        <TableColumn fx:id="colTipo" prefWidth="130.0" text="Tipo" />
                        <TableColumn fx:id="colAno" prefWidth="100.0" text="Ano Criação" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
                <HBox alignment="CENTER_RIGHT" prefHeight="50.0" spacing="10.0">
                    <children>
                        <Button fx:id="btnUpdate" onAction="#acaoAtualizar" mnemonicParsing="false" styleClass="btn-atualizar" text="ATUALIZAR SELECIONADO" />
                        <Button fx:id="btnDelete" onAction="#acaoExcluir" mnemonicParsing="false" styleClass="btn-excluir" text="EXCLUIR SELECIONADO" />
                    </children>
                </HBox>
            </children>
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" prefHeight="30.0" style="-fx-background-color: #000; -fx-border-color: #333; -fx-border-width: 1 0 0 0;" BorderPane.alignment="CENTER">
            <children>
                <Label fx:id="lblMensagem" text="Sistema pronto." textFill="#888">
                    <font>
                        <Font size="12.0" />
                    </font>
                </Label>
            </children>
            <padding>
                <Insets left="20.0" />
            </padding>
        </HBox>
    </bottom>
</BorderPane>